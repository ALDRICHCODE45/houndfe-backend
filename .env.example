# Database
DATABASE_URL=postgresql://user:password@localhost:5432/houndfe

# JWT Configuration
JWT_SECRET=your-secret-key-minimum-32-characters-long-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-characters-long-change-this-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# DigitalOcean Spaces Configuration
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_REGION=nyc3
SPACES_BUCKET=your-bucket-name
SPACES_ACCESS_KEY_ID=your-access-key-id
SPACES_SECRET_ACCESS_KEY=your-secret-access-key
SPACES_PUBLIC_BASE_URL=https://your-bucket-name.nyc3.cdn.digitaloceanspaces.com
SPACES_UPLOAD_MAX_MB=10
