// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum ProductType {
  PRODUCT
  SERVICE
}

enum UnitOfMeasure {
  UNIDAD
  CAJA
  BOLSA
  METRO
  CENTIMETRO
  KILOGRAMO
  GRAMO
  LITRO
}

enum IvaRate {
  IVA_16
  IVA_8
  IVA_0
  IVA_EXENTO
}

enum IepsRate {
  NO_APLICA
  IEPS_160
  IEPS_53
  IEPS_50
  IEPS_30_4
  IEPS_30
  IEPS_26_5
  IEPS_25
  IEPS_9
  IEPS_8
  IEPS_7
  IEPS_6
  IEPS_3
  IEPS_0
}

enum PurchaseCostMode {
  NET
  GROSS
}

// ============================================================================
// PROMOTIONS ENUMS
// ============================================================================

enum PromotionType {
  PRODUCT_DISCOUNT
  ORDER_DISCOUNT
  BUY_X_GET_Y
  ADVANCED
}

enum PromotionMethod {
  AUTOMATIC
  MANUAL
}

enum PromotionStatus {
  ACTIVE
  SCHEDULED
  ENDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum PromotionTargetType {
  CATEGORIES
  BRANDS
  PRODUCTS
}

enum CustomerScope {
  ALL
  REGISTERED_ONLY
  SPECIFIC
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum TargetSide {
  DEFAULT
  BUY
  GET
}

// ============================================================================
// SALES ENUMS
// ============================================================================

enum SaleStatus {
  DRAFT
}

enum SaleItemPriceSource {
  DEFAULT
  PRICE_LIST
  CUSTOM
}

enum SaleItemDiscountType {
  amount
  percentage
}

// ============================================================================
// CATEGORY
// ============================================================================

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("categories")
}

// ============================================================================
// BRAND
// ============================================================================

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("brands")
}

// ============================================================================
// TENANT
// ============================================================================

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  address   String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships          TenantMembership[]
  roles                Role[]
  products             Product[]
  variants             Variant[]
  lots                 Lot[]
  productImages        ProductImage[]
  fileObjects          FileObject[]
  priceLists           PriceList[]
  tierPrices           TierPrice[]
  variantPrices        VariantPrice[]
  variantTierPrices    VariantTierPrice[]
  orders               Order[]
  orderItems           OrderItem[]
  sales                Sale[]
  saleItems            SaleItem[]
  customers            Customer[]
  customerAddresses    CustomerAddress[]
  promotions           Promotion[]
  promotionTargetItems PromotionTargetItem[]
  promotionCustomers   PromotionCustomer[]
  promotionPriceLists  PromotionPriceList[]
  promotionDaysOfWeek  PromotionDayOfWeek[]

  @@map("tenants")
}

// ============================================================================
// PRODUCT MODEL (rewritten)
// ============================================================================

model Product {
  id                       String          @id @default(uuid())
  name                     String
  location                 String?
  description              String?
  type                     ProductType     @default(PRODUCT)
  // Unique per tenant — enforced via application layer or raw SQL partial index
  sku                      String?
  // Unique per tenant — enforced via application layer or raw SQL partial index
  barcode                  String?
  tenantId                 String
  unit                     UnitOfMeasure   @default(UNIDAD)
  satKey                   String?

  // Category (nullable — deleting category sets this to null)
  categoryId               String?
  category                 Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Brand (nullable — deleting brand sets this to null)
  brandId                  String?
  brand                    Brand?          @relation(fields: [brandId], references: [id], onDelete: SetNull)

  // Visibility / POS flags
  sellInPos                Boolean         @default(true)
  includeInOnlineCatalog   Boolean         @default(true)
  requiresPrescription     Boolean         @default(false)

  // Taxes
  chargeProductTaxes       Boolean         @default(true)
  ivaRate                  IvaRate         @default(IVA_16)
  iepsRate                 IepsRate        @default(NO_APLICA)

  // Purchase cost
  purchaseCostMode         PurchaseCostMode @default(NET)
  purchaseNetCostCents     Int             @default(0)
  purchaseGrossCostCents   Int             @default(0)

  // Inventory (applies when product has no variants)
  useStock                 Boolean         @default(true)
  useLotsAndExpirations    Boolean         @default(false)
  quantity                 Int             @default(0)
  minQuantity              Int             @default(0)

  // Has variants flag
  hasVariants              Boolean         @default(false)

  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  // Relations
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  saleItems     SaleItem[]
  images        ProductImage[]
  variants      Variant[]
  lots          Lot[]
  priceLists    PriceList[]

  @@index([tenantId])
  @@map("products")
}

// ============================================================================
// FILE OBJECT
// ============================================================================

model FileObject {
  id          String   @id @default(uuid())
  storageKey  String   @unique
  url         String
  mimeType    String
  sizeBytes   Int
  ownerType   String?
  ownerId     String?
  uploadedBy  String?
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productImage ProductImage?

  @@index([ownerType, ownerId])
  @@index([tenantId])
  @@map("files")
}

// ============================================================================
// PRODUCT IMAGE
// ============================================================================

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  variantId String?
  fileId    String?  @unique
  url       String
  isMain    Boolean  @default(false)
  sortOrder Int      @default(0)
  tenantId  String
  createdAt DateTime @default(now())

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant Variant?    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  file    FileObject? @relation(fields: [fileId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("product_images")
}

// ============================================================================
// VARIANT (simple by value — no cartesian combinations)
// ============================================================================

model Variant {
  id        String  @id @default(uuid())
  productId String
  name      String
  option    String?
  value     String?
  // Unique per tenant — enforced via application layer or raw SQL partial index
  sku       String?
  // Unique per tenant — enforced via application layer or raw SQL partial index
  barcode   String?
  tenantId  String
  quantity  Int     @default(0)
  minQuantity Int   @default(0)
  purchaseNetCostCents Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product      Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  images       ProductImage[]
  variantPrices VariantPrice[]
  saleItems    SaleItem[]

  @@index([tenantId])
  @@map("variants")
}

// ============================================================================
// VARIANT PRICE — per variant per price list
// ============================================================================

model VariantPrice {
  id          String @id @default(uuid())
  variantId   String
  priceListId String
  priceCents  Int
  tenantId    String

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variant   Variant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  tierPrices VariantTierPrice[]

  @@unique([tenantId, variantId, priceListId])
  @@index([tenantId])
  @@map("variant_prices")
}

model VariantTierPrice {
  id             String @id @default(uuid())
  variantPriceId String
  minQuantity    Int
  priceCents     Int
  tenantId       String

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variantPrice VariantPrice @relation(fields: [variantPriceId], references: [id], onDelete: Cascade)

  @@unique([tenantId, variantPriceId, minQuantity])
  @@index([tenantId])
  @@map("variant_tier_prices")
}

// ============================================================================
// LOT (inventory lots with expiration)
// ============================================================================

model Lot {
  id              String    @id @default(uuid())
  productId       String
  lotNumber       String
  tenantId        String
  quantity        Int       @default(0)
  manufactureDate DateTime?
  expirationDate  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // lotNumber unique per product
  @@unique([productId, lotNumber])
  @@index([tenantId])
  @@map("lots")
}

// ============================================================================
// GLOBAL PRICE LIST (business-level price list catalog)
// ============================================================================

model GlobalPriceList {
  id        String   @id @default(uuid())
  name      String   @unique
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  priceLists        PriceList[]
  customers         Customer[]
  promotionPriceLists PromotionPriceList[]

  @@map("global_price_lists")
}

// ============================================================================
// PRICE LIST
// ============================================================================

model PriceList {
  id                String @id @default(uuid())
  productId         String
  globalPriceListId String
  priceCents        Int
  tenantId          String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  globalPriceList GlobalPriceList @relation(fields: [globalPriceListId], references: [id], onDelete: Cascade)
  tierPrices      TierPrice[]
  variantPrices   VariantPrice[]

  @@unique([tenantId, productId, globalPriceListId])
  @@index([tenantId])
  @@map("price_lists")
}

// ============================================================================
// TIER PRICE (quantity-based tiers within a price list)
// ============================================================================

model TierPrice {
  id          String @id @default(uuid())
  priceListId String
  minQuantity Int
  priceCents  Int
  tenantId    String

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  // Unique threshold per price list
  @@unique([tenantId, priceListId, minQuantity])
  @@index([tenantId])
  @@map("tier_prices")
}

// ============================================================================
// ORDER MODEL
// ============================================================================

model Order {
  id           String      @id // UUID
  customerName String
  status       String      // DRAFT, PENDING, COMPLETED, CANCELLED
  tenantId     String
  createdAt    DateTime    @default(now())
  completedAt  DateTime?

  // Relations
  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  OrderItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("orders")
}

// ============================================================================
// ORDER ITEM MODEL
// ============================================================================

model OrderItem {
  id            String  @id @default(uuid())
  orderId       String
  productId     String
  productName   String
  quantity      Int
  unitPriceCents Int    // Stored in cents
  unitPriceCurrency String
  tenantId          String
  
  // Relations
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@map("order_items")
}

// ============================================================================
// SALE MODEL (POS Sales)
// ============================================================================

model Sale {
  id        String     @id @default(uuid())
  userId    String
  status    SaleStatus @default(DRAFT)
  tenantId  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  items  SaleItem[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([userId, status])
  @@map("sales")
}

// ============================================================================
// SALE ITEM MODEL
// ============================================================================

model SaleItem {
  id                String   @id @default(uuid())
  saleId            String
  productId         String
  variantId         String?
  productName       String
  variantName       String?
  quantity          Int
  unitPriceCents    Int
  unitPriceCurrency String   @default("MXN")
  originalPriceCents Int?
  priceSource SaleItemPriceSource?
  appliedPriceListId String?
  customPriceCents Int?
  discountType SaleItemDiscountType?
  discountValue Int?
  discountAmountCents Int?
  prePriceCentsBeforeDiscount Int?
  discountTitle String?
  discountedAt DateTime?
  tenantId          String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant Variant? @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@index([tenantId])
  @@map("sale_items")
}

// ============================================================================
// USER MODEL
// ============================================================================

model User {
  id                  String    @id
  email               String    @unique
  hashedPassword      String
  name                String
  isActive            Boolean   @default(true)
  hashedRefreshToken  String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenantMemberships TenantMembership[]
  sales             Sale[]

  @@map("users")
}

// ============================================================================
// RBAC MODELS
// ============================================================================

model Permission {
  id          String   @id @default(uuid())
  subject     String
  action      String
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@unique([subject, action])
  @@map("permissions")
}

model Role {
  id          String   @id @default(uuid())
  name        String
  tenantId    String?
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant             Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions        RolePermission[]
  tenantMemberships  TenantMembership[]

  @@unique([tenantId, name])
  @@index([tenantId])

  @@map("roles")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model TenantMembership {
  id       String @id @default(uuid())
  userId   String
  tenantId String
  roleId   String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId, roleId])
  @@index([tenantId])
  @@map("tenant_memberships")
}

// ============================================================================
// CUSTOMER
// ============================================================================

model Customer {
  id                    String   @id @default(uuid())
  firstName             String
  lastName              String?
  phoneCountryCode      String?
  phone                 String?
  email                 String?
  comments              String?
  tenantId              String

  tenant                Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Price list assignment (optional — auto-apply on sales)
  globalPriceListId     String?
  globalPriceList       GlobalPriceList? @relation(fields: [globalPriceListId], references: [id], onDelete: SetNull)

  // Billing data (all optional as a group)
  businessName          String?
  fiscalZipCode         String?
  rfc                   String?
  fiscalRegime          String?
  billingStreet         String?
  billingExteriorNumber String?
  billingInteriorNumber String?
  billingZipCode        String?
  billingNeighborhood   String?
  billingMunicipality   String?
  billingCity           String?
  billingState          String?

  addresses             CustomerAddress[]
  promotionCustomers    PromotionCustomer[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([tenantId])
  @@map("customers")
}

model CustomerAddress {
  id               String   @id @default(uuid())
  customerId       String
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  street           String
  exteriorNumber   String?
  interiorNumber   String?
  zipCode          String?
  neighborhood     String?
  municipality     String?
  city             String?
  state            String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId])
  @@map("customer_addresses")
}

// ============================================================================
// PROMOTIONS
// ============================================================================

model Promotion {
  id                     String              @id @default(uuid())
  title                  String
  type                   PromotionType
  method                 PromotionMethod
  status                 PromotionStatus     @default(ACTIVE)
  startDate              DateTime?
  endDate                DateTime?
  customerScope          CustomerScope       @default(ALL)

  // PRODUCT_DISCOUNT + ORDER_DISCOUNT
  discountType           DiscountType?
  discountValue          Int?

  // ORDER_DISCOUNT only
  minPurchaseAmountCents Int?

  // PRODUCT_DISCOUNT + BUY_X_GET_Y
  appliesTo              PromotionTargetType?

  // BUY_X_GET_Y + ADVANCED
  buyQuantity            Int?
  getQuantity            Int?
  getDiscountPercent     Int?

  // ADVANCED only
  buyTargetType          PromotionTargetType?
  getTargetType          PromotionTargetType?
  tenantId               String

  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  tenant                 Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Relations
  targetItems            PromotionTargetItem[]
  customers              PromotionCustomer[]
  priceLists             PromotionPriceList[]
  daysOfWeek             PromotionDayOfWeek[]

  @@index([tenantId])
  @@index([type])
  @@index([method])
  @@index([status, startDate, endDate])
  @@map("promotions")
}

model PromotionTargetItem {
  id          String              @id @default(uuid())
  promotionId String
  side        TargetSide          @default(DEFAULT)
  targetType  PromotionTargetType
  targetId    String
  tenantId    String

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@unique([promotionId, side, targetType, targetId])
  @@index([tenantId])
  @@index([targetType, targetId])
  @@map("promotion_target_items")
}

model PromotionCustomer {
  id          String @id @default(uuid())
  promotionId String
  customerId  String
  tenantId    String

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([promotionId, customerId])
  @@index([tenantId])
  @@map("promotion_customers")
}

model PromotionPriceList {
  id                String @id @default(uuid())
  promotionId       String
  globalPriceListId String
  tenantId          String

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  promotion       Promotion       @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  globalPriceList GlobalPriceList @relation(fields: [globalPriceListId], references: [id], onDelete: Cascade)

  @@unique([promotionId, globalPriceListId])
  @@index([tenantId])
  @@map("promotion_price_lists")
}

model PromotionDayOfWeek {
  id          String    @id @default(uuid())
  promotionId String
  day         DayOfWeek
  tenantId    String

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@unique([promotionId, day])
  @@index([tenantId])
  @@map("promotion_days_of_week")
}
