// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum ProductType {
  PRODUCT
  SERVICE
}

enum UnitOfMeasure {
  UNIDAD
  CAJA
  BOLSA
  METRO
  CENTIMETRO
  KILOGRAMO
  GRAMO
  LITRO
}

enum IvaRate {
  IVA_16
  IVA_8
  IVA_0
  IVA_EXENTO
}

enum IepsRate {
  NO_APLICA
  IEPS_160
  IEPS_53
  IEPS_50
  IEPS_30_4
  IEPS_30
  IEPS_26_5
  IEPS_25
  IEPS_9
  IEPS_8
  IEPS_7
  IEPS_6
  IEPS_3
  IEPS_0
}

enum PurchaseCostMode {
  NET
  GROSS
}

// ============================================================================
// CATEGORY
// ============================================================================

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("categories")
}

// ============================================================================
// BRAND
// ============================================================================

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("brands")
}

// ============================================================================
// PRODUCT MODEL (rewritten)
// ============================================================================

model Product {
  id                       String          @id @default(uuid())
  name                     String
  location                 String?
  description              String?
  type                     ProductType     @default(PRODUCT)
  sku                      String?         @unique
  barcode                  String?         @unique
  unit                     UnitOfMeasure   @default(UNIDAD)
  satKey                   String?

  // Category (nullable — deleting category sets this to null)
  categoryId               String?
  category                 Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Brand (nullable — deleting brand sets this to null)
  brandId                  String?
  brand                    Brand?          @relation(fields: [brandId], references: [id], onDelete: SetNull)

  // Visibility / POS flags
  sellInPos                Boolean         @default(true)
  includeInOnlineCatalog   Boolean         @default(true)
  requiresPrescription     Boolean         @default(false)

  // Taxes
  chargeProductTaxes       Boolean         @default(true)
  ivaRate                  IvaRate         @default(IVA_16)
  iepsRate                 IepsRate        @default(NO_APLICA)

  // Purchase cost
  purchaseCostMode         PurchaseCostMode @default(NET)
  purchaseNetCostCents     Int             @default(0)
  purchaseGrossCostCents   Int             @default(0)

  // Inventory (applies when product has no variants)
  useStock                 Boolean         @default(true)
  useLotsAndExpirations    Boolean         @default(false)
  quantity                 Int             @default(0)
  minQuantity              Int             @default(0)

  // Has variants flag
  hasVariants              Boolean         @default(false)

  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  // Relations
  orderItems    OrderItem[]
  images        ProductImage[]
  variants      Variant[]
  lots          Lot[]
  priceLists    PriceList[]

  @@map("products")
}

// ============================================================================
// PRODUCT IMAGE
// ============================================================================

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  variantId String?
  url       String
  isMain    Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant Variant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

// ============================================================================
// VARIANT (simple by value — no cartesian combinations)
// ============================================================================

model Variant {
  id        String  @id @default(uuid())
  productId String
  name      String
  option    String?
  value     String?
  sku       String? @unique
  barcode   String? @unique
  quantity  Int     @default(0)
  minQuantity Int   @default(0)
  purchaseNetCostCents Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product      Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  images       ProductImage[]
  variantPrices VariantPrice[]

  @@map("variants")
}

// ============================================================================
// VARIANT PRICE — per variant per price list
// ============================================================================

model VariantPrice {
  id          String @id @default(uuid())
  variantId   String
  priceListId String
  priceCents  Int

  variant   Variant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  tierPrices VariantTierPrice[]

  @@unique([variantId, priceListId])
  @@map("variant_prices")
}

model VariantTierPrice {
  id             String @id @default(uuid())
  variantPriceId String
  minQuantity    Int
  priceCents     Int

  variantPrice VariantPrice @relation(fields: [variantPriceId], references: [id], onDelete: Cascade)

  @@unique([variantPriceId, minQuantity])
  @@map("variant_tier_prices")
}

// ============================================================================
// LOT (inventory lots with expiration)
// ============================================================================

model Lot {
  id              String    @id @default(uuid())
  productId       String
  lotNumber       String
  quantity        Int       @default(0)
  manufactureDate DateTime?
  expirationDate  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // lotNumber unique per product
  @@unique([productId, lotNumber])
  @@map("lots")
}

// ============================================================================
// GLOBAL PRICE LIST (business-level price list catalog)
// ============================================================================

model GlobalPriceList {
  id        String   @id @default(uuid())
  name      String   @unique
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  priceLists PriceList[]

  @@map("global_price_lists")
}

// ============================================================================
// PRICE LIST
// ============================================================================

model PriceList {
  id                String @id @default(uuid())
  productId         String
  globalPriceListId String
  priceCents        Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product         Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  globalPriceList GlobalPriceList @relation(fields: [globalPriceListId], references: [id], onDelete: Cascade)
  tierPrices      TierPrice[]
  variantPrices   VariantPrice[]

  @@unique([productId, globalPriceListId])
  @@map("price_lists")
}

// ============================================================================
// TIER PRICE (quantity-based tiers within a price list)
// ============================================================================

model TierPrice {
  id          String @id @default(uuid())
  priceListId String
  minQuantity Int
  priceCents  Int

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  // Unique threshold per price list
  @@unique([priceListId, minQuantity])
  @@map("tier_prices")
}

// ============================================================================
// ORDER MODEL
// ============================================================================

model Order {
  id           String      @id // UUID
  customerName String
  status       String      // DRAFT, PENDING, COMPLETED, CANCELLED
  createdAt    DateTime    @default(now())
  completedAt  DateTime?

  // Relations
  items OrderItem[]

  @@map("orders")
}

// ============================================================================
// ORDER ITEM MODEL
// ============================================================================

model OrderItem {
  id            String  @id @default(uuid())
  orderId       String
  productId     String
  productName   String
  quantity      Int
  unitPriceCents Int    // Stored in cents
  unitPriceCurrency String
  
  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ============================================================================
// USER MODEL
// ============================================================================

model User {
  id                  String    @id
  email               String    @unique
  hashedPassword      String
  name                String
  isActive            Boolean   @default(true)
  hashedRefreshToken  String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  roles UserRole[]

  @@map("users")
}

// ============================================================================
// RBAC MODELS
// ============================================================================

model Permission {
  id          String   @id @default(uuid())
  subject     String
  action      String
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@unique([subject, action])
  @@map("permissions")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}
