// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// PRODUCT MODEL
// ============================================================================
// El modelo de Prisma representa la TABLA en la base de datos.
// 
// NOTA: Esto es INFRASTRUCTURE, no dominio.
// El dominio tiene sus propias entidades (Product) que son independientes.
//
// En algunos enfoques (Domain-Driven Design con ORMs como Prisma),
// el modelo de DB puede reflejar la entidad de dominio. En otros,
// son completamente separados.
//
// PARA ESTE EJEMPLO: Usamos enfoque pragmático donde el modelo Prisma
// representa la estructura de persistencia.
// ============================================================================

model Product {
  id        String   @id // UUID
  name      String
  price     Int      // Stored in cents (integer) - Money Value Object pattern
  currency  String   // USD, EUR, ARS, MXN
  sku       String   @unique
  stock     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orderItems OrderItem[]

  @@map("products")
}

// ============================================================================
// ORDER MODEL
// ============================================================================

model Order {
  id           String      @id // UUID
  customerName String
  status       String      // DRAFT, PENDING, COMPLETED, CANCELLED
  createdAt    DateTime    @default(now())
  completedAt  DateTime?

  // Relations
  items OrderItem[]

  @@map("orders")
}

// ============================================================================
// ORDER ITEM MODEL
// ============================================================================
// Relación: Order 1:N OrderItems
//           Product 1:N OrderItems
// 
// NOTA: OrderItem es parte del Aggregate Order, pero en Prisma
//modelamos como tabla separada por practicidad.
// En DDD puro, OrderItem podría no tener su propia tabla.
// ============================================================================

model OrderItem {
  id            String  @id @default(uuid())
  orderId       String
  productId     String
  productName   String
  quantity      Int
  unitPriceCents Int    // Stored in cents
  unitPriceCurrency String
  
  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ============================================================================
// USER MODEL
// ============================================================================
// User table for authentication and authorization.
// Part of the auth bounded context.
// ============================================================================

model User {
  id                  String    @id                // UUID from crypto.randomUUID()
  email               String    @unique
  hashedPassword      String
  name                String
  isActive            Boolean   @default(true)
  hashedRefreshToken  String?                      // nullable — null when logged out
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  roles UserRole[]

  @@map("users")
}

// ============================================================================
// RBAC MODELS
// ============================================================================
// Permission, Role, RolePermission, UserRole models for authorization.
// Part of the auth bounded context.
// ============================================================================

model Permission {
  id          String   @id @default(uuid())
  subject     String
  action      String
  description String?
  createdAt   DateTime @default(now())

  // Relations
  roles RolePermission[]

  @@unique([subject, action])
  @@map("permissions")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  // Relations
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}
