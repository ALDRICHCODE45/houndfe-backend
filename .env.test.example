# Test-environment file — committed template.
#
# Copy this file to `.env.test` (which IS gitignored, matching the
# `.env` / `.env.local` pattern) and adjust values to match your local
# `docker compose up postgres-test`. The committed `.env.test.example`
# mirrors `.env.example` so every required Joi key is present with a
# safe dummy value; integration specs that boot the full Nest app via
# `ConfigModule` will pass `buildEnvValidationSchema()` against this
# file.
#
# Why DATABASE_URL points at port 5433: the integration test DB
# service in `docker-compose.yml` (`postgres-test`) listens on 5433 on
# the host. The dev DB (`postgres`) is on 5432 and MUST remain
# untouched by tests — see the test/integration/README.md.
DATABASE_URL=postgresql://admin:secreto@localhost:5433/nest-practice-test

# JWT — required by Joi (min length 32). Safe dummy values; integration
# specs that need real JWT flows mint their own short-lived tokens via
# `signToken` helpers, so the secret is only validated for shape.
JWT_SECRET=integration-test-jwt-secret-padded-to-min-32-chars-aaaa
JWT_REFRESH_SECRET=integration-test-jwt-refresh-padded-to-min-32-chars-bbbb
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# SPACES — required by Joi (uri + non-empty strings). Integration
# specs do NOT call S3 — these are present so the Joi validation in
# ConfigModule boots even if a test imports the app module.
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_REGION=nyc3
SPACES_BUCKET=houndfe-integration-test-bucket
SPACES_ACCESS_KEY_ID=integration-test-access-key-id
SPACES_SECRET_ACCESS_KEY=integration-test-secret-access-key
SPACES_PUBLIC_BASE_URL=https://houndfe-integration-test-bucket.nyc3.cdn.digitaloceanspaces.com
SPACES_UPLOAD_MAX_MB=10

# NODE_ENV — required (no silent default in `buildEnvValidationSchema`).
# Setting it to `test` keeps the fail-closed posture honest (e.g.
# INNGEST_DEV / MAIL_FROM / APP_WEB_URL stay optional) while making it
# unambiguous from logs that we're in the test environment.
NODE_ENV=test

# Date-range normalization — business timezone.
# PromotionsService normalizes `startDate`/`endDate` to the local
# start-of-day / end-of-day in this IANA timezone before persisting.
# Override per-suite if a specific spec wants a fixed zone.
PROMOTIONS_BUSINESS_TIMEZONE=America/Mexico_City

# Set to `1` to skip every DB-hitting integration spec. The promotion
# repo integration spec + tenant-isolation spec already guard on this.
# Useful for running `pnpm test:integration` on a machine without a
# test DB up without every suite throwing a connection error.
SKIP_DB_INTEGRATION=0
